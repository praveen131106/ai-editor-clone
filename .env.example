# ─── Supabase ────────────────────────────────────────────────────────────────
# Local dev: get these from running `supabase start`
# Production: get from your Supabase project settings → API
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-local-publishable-key
# Legacy fallback (older Supabase key model):
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# ─── RevenueCat ──────────────────────────────────────────────────────────────
# From RevenueCat dashboard → Project → API Keys
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=

# ─── Sentry ──────────────────────────────────────────────────────────────────
# From sentry.io → Project → Settings → Client Keys (DSN)
EXPO_PUBLIC_SENTRY_DSN=
# Auth token for source map uploads during EAS build (CI/CD secret)
SENTRY_AUTH_TOKEN=

# ─── PostHog ─────────────────────────────────────────────────────────────────
# From posthog.com → Project → Settings → Project API Key
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# AI service secrets - set these as Supabase Edge Function secrets, not public Expo vars.
# supabase secrets set GEMINI_API_KEY=...
# supabase secrets set REMOVE_BG_API_KEY=...
# supabase secrets set CLIPDROP_API_KEY=...
# supabase secrets set HUGGINGFACE_API_KEY=...
GEMINI_API_KEY=
GEMINI_PROMPT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation
REMOVE_BG_API_KEY=
CLIPDROP_API_KEY=
HUGGINGFACE_API_KEY=
HUGGINGFACE_SEGMENTATION_MODEL=briaai/RMBG-1.4
